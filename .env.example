# Scraping
APIFY_API_TOKEN=

# Funding Data — SEC EDGAR Form D (free, public, no key required)
# EDGAR requires a descriptive User-Agent (name + contact email) on every request or it 403s.
EDGAR_USER_AGENT=Your Name your.email@example.com

# Hiring signal - Adzuna (free tier: 25/min, 250/day, 1,000/week, 2,500/month)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Greenhouse and Lever need no key at all - see python/hiring_ats_lookup.py

# Redesign v2, Tier 1: Product Hunt launch monitoring (Branch D, TIMING signal)
# Free developer token - https://www.producthunt.com/v2/oauth/applications
# Rate limit: 900 req/15min. Default ToS: non-commercial use only (fine for
# this portfolio project - see python/producthunt_launches.py docstring).
PRODUCT_HUNT_API_TOKEN=

# Enrichment (Clay replaces direct Hunter.io/Apollo calls)
CLAY_WEBHOOK_URL=
CLAY_API_KEY=

# AI Generation
GEMINI_API_KEY=
GEMINI_API_KEY_2=                # Dual-key fallback for rate limits

# CRM
HUBSPOT_PRIVATE_APP_TOKEN=

# Postgres — hosted on Supabase (ADR-004), free tier, no credit card required
# Find this under your Supabase project: Settings -> Database -> Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Output
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=     # Path to service account key file
DISCORD_WEBHOOK_URL=             # Per-lead notifications, fires once per qualifying lead
# Redesign v2, Tier 2: separate ops-progress and SDR-digest channels/webhooks
# - phase-by-phase status noise vs. the one clean final summary an SDR opens.
DISCORD_PROGRESS_WEBHOOK_URL=
DISCORD_SDR_DIGEST_WEBHOOK_URL=
# Redesign v2, Tier 5: human-in-the-loop Clay enrichment requests (export
# CSV attached) - the pipeline auto-detects the enriched file dropped back
# into data/clay/incoming_domain/ or data/clay/incoming_demographics/ and
# resumes automatically, no manual re-trigger required (see
# python/full_pipeline_run.py's resume_after_enrichment()).
DISCORD_CLAY_ENRICHMENT_WEBHOOK_URL=
# Redesign v2, Tier 6: a real Discord bot (not just a webhook - a webhook
# can only post out, not read messages back) that watches #clay-enrichment
# for the user's enriched CSV attachment and imports it immediately, no
# local file-drop step required. Setup: discord.com/developers/applications
# -> New Application -> Bot tab -> Reset Token -> DISCORD_BOT_TOKEN, enable
# "Message Content Intent" on that same tab, then OAuth2 -> URL Generator
# (scope: bot: View Channel, Read Message History, Send Messages, Attach
# Files) to invite it to the server. DISCORD_CLAY_CHANNEL_ID is
# #clay-enrichment's channel ID (enable Developer Mode in Discord's user
# settings, then right-click the channel -> Copy Channel ID). Both optional
# - if unset, the bot simply doesn't start; the local-folder + poller path
# (above) still works fully on its own.
DISCORD_BOT_TOKEN=
DISCORD_CLAY_CHANNEL_ID=

# Config
ICP_SCORE_THRESHOLD=70           # Minimum score to qualify lead
LOOKBACK_DAYS_FUNDING=90         # Days back for funding events
LOOKBACK_DAYS_JOBS=60            # Days back for job postings
DEDUP_WINDOW_DAYS=7              # Skip company if seen within N days
