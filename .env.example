# Scraping
APIFY_API_TOKEN=

# Funding Data — SEC EDGAR Form D (free, public, no key required)
# EDGAR requires a descriptive User-Agent (name + contact email) on every request or it 403s.
EDGAR_USER_AGENT=Your Name your.email@example.com

# Hiring signal - Adzuna (free tier: 25/min, 250/day, 1,000/week, 2,500/month)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Greenhouse and Lever need no key at all - see python/hiring_ats_lookup.py

# Enrichment (Clay replaces direct Hunter.io/Apollo calls)
CLAY_WEBHOOK_URL=
CLAY_API_KEY=

# AI Generation
GEMINI_API_KEY=
GEMINI_API_KEY_2=                # Dual-key fallback for rate limits

# CRM
HUBSPOT_PRIVATE_APP_TOKEN=

# Postgres — hosted on Supabase (ADR-004), free tier, no credit card required
# Find this under your Supabase project: Settings -> Database -> Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Output
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=     # Path to service account key file
DISCORD_WEBHOOK_URL=

# Config
ICP_SCORE_THRESHOLD=70           # Minimum score to qualify lead
LOOKBACK_DAYS_FUNDING=90         # Days back for funding events
LOOKBACK_DAYS_JOBS=60            # Days back for job postings
DEDUP_WINDOW_DAYS=7              # Skip company if seen within N days
